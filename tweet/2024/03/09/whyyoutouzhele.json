[{"id":"1766143787187704190","name":"李老师不是你老师","createdDate":"2024-03-09 00:47:46","content":"https://t.co/B6dqeRwpbA","images":"","videos":""},{"id":"1766142609842430282","name":"李老师不是你老师","createdDate":"2024-03-09 00:43:06","content":"“国中之国”\n河北网友投稿称，目前河北通往北京的道路全部都被封死，从河北想要进入北京需要走指定的检察站刷身份证进入。 https://t.co/Ftdt2Mn3jr","images":"/temp/image/2024/w-Month-3/1766142609842430282_0.jpg,","videos":""},{"id":"1766138488724836427","name":"李老师不是你老师","createdDate":"2024-03-09 00:26:43","content":"3月8日，深圳大学附属中学 https://t.co/cJorlv9h9o","images":"/temp/image/2024/w-Month-3/1766138488724836427_0.jpg,/temp/image/2024/w-Month-3/1766138488724836427_1.jpg,/temp/image/2024/w-Month-3/1766138488724836427_2.jpg,/temp/image/2024/w-Month-3/1766138488724836427_3.jpg,","videos":""},{"id":"1766133833076818135","name":"李老师不是你老师","createdDate":"2024-03-09 00:08:13","content":"https://t.co/RrrgAHhsyh","images":"","videos":"/temp/video/2024/w-Month-3/q-Day-09/whyyoutouzhele/1766133833076818135_0.jpg,"},{"id":"1766133514540400953","name":"李老师不是你老师","createdDate":"2024-03-09 00:06:57","content":"https://t.co/ZCY1nY2Bzc","images":"/temp/image/2024/w-Month-3/1766133514540400953_0.jpg,/temp/image/2024/w-Month-3/1766133514540400953_1.jpg,/temp/image/2024/w-Month-3/1766133514540400953_2.jpg,","videos":""},{"id":"1766133063350641025","name":"李老师不是你老师","createdDate":"2024-03-09 00:05:10","content":"3月8日晚，哈尔滨工业大学深圳校区军训时，4000多名学生被体罚半个多小时，直接导致两名学生突发疾病被救护车运走。\n同学们称，当晚他们先是被罚站姿十几分贼，之后又被罚蹲姿十几分钟，随后被要求挨个点名时声嘶力竭地大吼。直至两名学生被送上救护车也没有停止。期间总教官张某明还让大家等他一下，他要拍个视频。\n此举引发了广大学生的愤怒，同学们表示，军训总教官张某明多次拍摄军训内容发布在抖音上博取流量，自己还经营一家MCN公司，质疑今晚的体罚和折腾只是为了折腾学生给账号拍摄抖音素材。","images":"/temp/image/2024/w-Month-3/1766133063350641025_0.jpg,/temp/image/2024/w-Month-3/1766133063350641025_1.jpg,/temp/image/2024/w-Month-3/1766133063350641025_2.jpg,/temp/image/2024/w-Month-3/1766133063350641025_3.jpg,","videos":""}]