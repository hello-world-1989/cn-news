[{"id":"1743276334288101623","name":"李老师不是你老师","createdDate":"2024-01-05 22:20:41","content":"近日，有博主称，当前乡镇政府里的最大支出已经不是招待费，而是宣传广告费。\n学习要统一购买笔记本，广告牌要高大上营造氛围，各种制度要统一规范上墙，党建，宣传，纪检，安全生产都要做广告牌。每年的广告费少则几十万，多则上百万。 https://t.co/dbQ9KEi8LN","images":"/temp/image/2024/y-Month-1/1743276334288101623_0.jpg,","videos":""},{"id":"1743260239359569924","name":"李老师不是你老师","createdDate":"2024-01-05 21:16:43","content":"另有网友补充 https://t.co/oghV17lVmD","images":"/temp/image/2024/y-Month-1/1743260239359569924_0.jpg,","videos":""},{"id":"1743259619659600332","name":"李老师不是你老师","createdDate":"2024-01-05 21:14:16","content":"业内网友补充 https://t.co/WMXB1wetiB","images":"/temp/image/2024/y-Month-1/1743259619659600332_0.jpg,","videos":""}]